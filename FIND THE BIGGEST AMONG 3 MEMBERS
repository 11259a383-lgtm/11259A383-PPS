#include <stdio.h>

int main() {
    char ch;

    // Ask user for input
    printf("Enter a character: ");
    scanf("%c", &ch);

    // Output ASCII value using %d
    printf("The ASCII value of '%c' is %d\n", ch, ch);

    return 0;
}
