#include <stdio.h>

int main() {
    int choice, n, sum = 0;

    printf("Choose the series to sum:\n");
    printf("1. Sum of first N natural numbers (1 + 2 + ... + N)\n");
    printf("2. Sum of first N even numbers (2 + 4 + ... + 2N)\n");
    printf("3. Sum of first N odd numbers (1 + 3 + ... + 2N-1)\n");
    printf("Enter your choice (1-3): ");
    scanf("%d", &choice);

    printf("Enter the value of N: ");
    scanf("%d", &n);

    switch (choice) {
        case 1:
            for (int i = 1; i <= n; i++) {
                sum += i;
            }
            printf("The sum of the series is: %d\n", sum);
            break;

        case 2:
            for (int i = 1; i <= n; i++) {
                sum += (2 * i);
            }
            printf("The sum of the series is: %d\n", sum);
            break;

        case 3:
            for (int i = 1; i <= n; i++) {
                sum += (2 * i - 1);
            }
            printf("The sum of the series is: %d\n", sum);
            break;

        default:
            printf("Invalid choice! Please enter a number between 1 and 3.\n");
    }

    return 0;
}


