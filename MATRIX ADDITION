#include <stdio.h>

int main() {
    int r, c, i, j;
    int a[10][10], b[10][10], sum[10][10];

    printf("Enter rows and cols: ");
    scanf("%d %d", &r, &c);

    // Input matrices and calculate sum
    for(i=0; i<r; i++)
        for(j=0; j<c; j++) {
            printf("Element a[%d][%d] and b[%d][%d]: ", i, j, i, j);
            scanf("%d %d", &a[i][j], &b[i][j]);
            sum[i][j] = a[i][j] + b[i][j];
        }

    // Display result
    printf("Resultant Matrix:\n");
    for(i=0; i<r; i++) {
        for(j=0; j<c; j++)
            printf("%d ", sum[i][j]);
        printf("\n");
    }
    return 0;
}

